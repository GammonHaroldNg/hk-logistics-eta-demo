# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ClickUp API token (required for ClickUp lists and "Start from ClickUp")
# Get it from: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=your_clickup_api_token_here

# ClickUp Space ID (optional). If lists are empty, set this to your space ID.
# Find it in the ClickUp URL when viewing a space: .../space/SPACE_ID/...
CLICKUP_SPACE_ID=901810032596

# Optional: PostgreSQL connection (for trips, delivery targets, truck sync)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
